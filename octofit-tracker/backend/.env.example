# Backend Configuration

# MongoDB connection URI
# Default: mongodb://localhost:27017/octofit_db
MONGO_URI=mongodb://localhost:27017/octofit_db

# Codespaces configuration
# Automatically set by GitHub Codespaces
# When CODESPACE_NAME is set, API base URL becomes:
# https://$CODESPACE_NAME-8000.app.github.dev
# 
# When not set (local development), API base URL is:
# http://localhost:8000
CODESPACE_NAME=

# Backend port (default: 8000)
PORT=8000
