# Frontend environment variables for Vite
# Copy this file to .env.local and fill in values

# Required when running in GitHub Codespaces.
# Set this to your Codespace name so the frontend can reach the backend API:
# https://${VITE_CODESPACE_NAME}-8000.app.github.dev
#
# Find your Codespace name in the URL: https://<CODESPACE_NAME>.github.dev
# Leave empty for local development (falls back to http://localhost:8000)
VITE_CODESPACE_NAME=
